{
    "name": "nawasara/vault",
    "description": "Encrypted credential management for the Nawasara superapp framework — service groups, multi-instance support, access log, and one-click test connection.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "nawasara",
        "laravel",
        "vault",
        "credentials",
        "encryption",
        "secrets",
        "audit"
    ],
    "authors": [
        {
            "name": "Pringgo J. Saputro",
            "email": "odyinggo@gmail.com",
            "role": "Lead Developer"
        }
    ],
    "support": {
        "issues": "https://github.com/nawasara/vault/issues",
        "source": "https://github.com/nawasara/vault"
    },
    "autoload": {
        "psr-4": {
            "Nawasara\\Vault\\": "src/"
        }
    },
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0|^12.0",
        "spatie/laravel-permission": "^6.0",
        "spatie/laravel-activitylog": "^4.9",
        "nawasara/ui": "*",
        "livewire/livewire": "^3.0"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Nawasara\\Vault\\VaultServiceProvider"
            ],
            "aliases": {
                "Vault": "Nawasara\\Vault\\Facades\\Vault"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
